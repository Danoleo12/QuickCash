<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Development_01">

        <!--
             TODO: Before you run your application, you need a Google Maps API key.

             To get one, follow the directions here:

                https://developers.google.com/maps/documentation/android-sdk/get-api-key

             Once you have your API key (it starts with "AIza"), define a new property in your
             project's local.properties file (e.g. MAPS_API_KEY=Aiza...), and replace the
             "YOUR_API_KEY" string in this file with "${MAPS_API_KEY}".
        -->
        <!-- API Key commented for security:
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyAa5wFRimq1RI2JV_DsrZRt2xD2uaRQrXg" />
        -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="REPLACE_WITH_YOUR_MAPS_API_KEY" />

        <activity
            android:name=".core.ui.MapsActivity"
            android:exported="false"
            android:label="@string/title_activity_maps" />
        <activity
            android:name=".core.ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Development_01">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".core.ui.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.Development_01"></activity>
        <activity
            android:name=".core.ui.ForgotPasswordActivity"
            android:exported="true"
            android:theme="@style/Theme.Development_01"></activity>
        <activity
            android:name=".core.ui.EmployeeActivity"
            android:exported="true"
            android:theme="@style/Theme.Development_01"></activity>
        <activity
            android:name=".core.ui.EmployerActivity"
            android:exported="true"
            android:theme="@style/Theme.Development_01"></activity>
        <activity
            android:name=".core.ui.SearchActivity"
            android:exported="false"
            android:theme="@style/Theme.Development_01"></activity>
        <activity
            android:name=".core.ui.PostSearchActivity"
            android:exported="false"
            android:theme="@style/Theme.Development_01"></activity>
        <activity
            android:name=".core.ui.RatingActivity"
            android:exported="false"
            android:theme="@style/Theme.Development_01" />
        <activity android:name=".core.ui.JobDescription" />
        <activity android:name=".core.ui.PostDescription" />
        <activity android:name=".core.ui.PreferredJobsActivity" />
        <activity android:name=".core.ui.HiredEmployeesActivity" />

        <service
            android:name="com.paypal.android.sdk.payments.PayPalService"
            android:exported="false" />

        <activity
            android:name=".core.ui.ApplyJobActivity"
            android:exported="true"
            android:theme="@style/Theme.Development_01">
        </activity>

        <activity
            android:name=".core.ui.EmployerJobViewActivity"
            android:exported="false"
            android:theme="@style/Theme.Development_01" />
        <activity
            android:name=".core.ui.JobApplicationsActivity"
            android:exported="false"
            android:theme="@style/Theme.Development_01" />
        <activity
            android:name=".core.ui.ResumeViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.Development_01" />
        <activity
            android:name=".core.ui.EmployerPayPal"
            android:exported="false"
            android:theme="@style/Theme.Development_01" />

        <activity
            android:name=".core.ui.PaymentSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Development_01">
        </activity>
    </application>

</manifest>