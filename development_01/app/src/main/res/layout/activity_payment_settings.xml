<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvPaymentSettingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Settings"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvVerificationStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Status: Loading..."
        android:textColor="#4CAF50"
        app:layout_constraintTop_toBottomOf="@id/tvPaymentSettingsTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etAccountName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Account Name"
        android:inputType="textPersonName"
        app:layout_constraintTop_toBottomOf="@id/tvVerificationStatus"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etBankName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Bank Name"
        android:inputType="text"
        app:layout_constraintTop_toBottomOf="@id/etAccountName"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etAccountNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Account Number"
        android:inputType="number"
        app:layout_constraintTop_toBottomOf="@id/etBankName"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etRoutingNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Routing Number"
        android:inputType="number"
        app:layout_constraintTop_toBottomOf="@id/etAccountNumber"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnSavePaymentInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Save Payment Information"
        app:layout_constraintTop_toBottomOf="@id/etRoutingNumber"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
