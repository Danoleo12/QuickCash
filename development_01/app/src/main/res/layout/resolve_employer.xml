<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/employer_role"
        android:layout_width="182dp"
        android:layout_height="41dp"
        android:layout_marginStart="166dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="148dp"
        android:text="Employer Dashboard"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.623"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/fixedEmployerName"
        android:layout_width="116dp"
        android:layout_height="30dp"
        android:layout_marginTop="32dp"
        android:text="User Name"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@+id/employer_role"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="9dp" />

    <TextView
        android:id="@+id/fixedEmployerEmail"
        android:layout_width="116dp"
        android:layout_height="30dp"

        android:layout_marginTop="20dp"
        android:text="User Email"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@+id/fixedEmployerName"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="9dp" />

    <Button
        android:id="@+id/employerLogOut"
        android:layout_width="150dp"
        android:layout_height="51dp"
        android:layout_marginTop="64dp"
        android:backgroundTint="@android:color/holo_red_dark"
        android:text="Log Out"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/seeAppls" />

    <TextView
        android:id="@+id/employerEmail"
        android:layout_width="230dp"
        android:layout_height="30dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="20dp"
        android:text="TextView"
        android:textAlignment="center"
        app:layout_constraintStart_toEndOf="@+id/fixedEmployerEmail"
        app:layout_constraintTop_toBottomOf="@+id/employerName" />

    <TextView
        android:id="@+id/employerName"
        android:layout_width="225dp"
        android:layout_height="30dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="32dp"
        android:text="TextView"
        android:textAlignment="center"
        app:layout_constraintStart_toEndOf="@+id/fixedEmployerName"
        app:layout_constraintTop_toBottomOf="@+id/employer_role" />

    <Button
        android:id="@+id/addJob"
        android:layout_width="100dp"
        android:layout_height="70dp"
        android:layout_marginTop="304dp"
        android:layout_marginEnd="16dp"
        android:text="Post jobs"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/employerEmail" />

    <Button
        android:id="@+id/seeAppls"
        android:layout_width="120dp"
        android:layout_height="70dp"
        android:layout_marginTop="304dp"
        android:layout_marginEnd="20dp"
        android:text="View Applications"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        app:layout_constraintEnd_toStartOf="@+id/addJob"
        app:layout_constraintHorizontal_bias="0.806"
        app:layout_constraintStart_toEndOf="@+id/viewFavorites"
        app:layout_constraintTop_toBottomOf="@+id/employerEmail" />

    <Button
        android:id="@+id/viewFavorites"
        android:layout_width="100dp"
        android:layout_height="70dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="304dp"
        android:text="View Favorites"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fixedEmployerEmail" />
    <Button
        android:id="@+id/btnPayPal"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="PayPal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/addJob" />


</androidx.constraintlayout.widget.ConstraintLayout>